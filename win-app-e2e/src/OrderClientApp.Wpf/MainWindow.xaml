<Window x:Class="OrderClientApp.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="発注管理クライアント" Height="500" Width="860">
    <Grid Margin="24">
        <Grid x:Name="LoginView">
            <Border BorderBrush="#D1D5DB" BorderThickness="1" Padding="24" CornerRadius="8" Width="360" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="ログイン" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,16" />
                    <TextBlock Text="ユーザー名" />
                    <TextBox x:Name="UsernameTextBox" Margin="0,4,0,12" />
                    <TextBlock Text="パスワード" />
                    <PasswordBox x:Name="PasswordBox" Margin="0,4,0,12" />
                    <TextBlock x:Name="ErrorTextBlock" Foreground="#B91C1C" Margin="0,0,0,12" TextWrapping="Wrap" Visibility="Collapsed" />
                    <Button Content="ログイン" Height="36" Click="LoginButton_Click" />
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="DashboardView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,20">
                <TextBlock x:Name="HeaderTextBlock" FontSize="20" FontWeight="SemiBold" />
                <Button Content="ログアウト" Width="100" DockPanel.Dock="Right" Click="LogoutButton_Click" />
            </DockPanel>

            <Border Grid.Row="1" Padding="12" Background="#F3F4F6" CornerRadius="8" Margin="0,0,0,12">
                <TextBlock x:Name="DashboardInfoTextBlock" TextWrapping="Wrap" />
            </Border>

            <StackPanel Grid.Row="2">
                <TextBlock Text="ナビゲーション（権限に応じて表示）" FontWeight="SemiBold" Margin="0,0,0,8" />
                <WrapPanel>
                    <Button x:Name="OrderManagementButton" Content="発注管理" Width="120" Margin="0,0,8,8" IsEnabled="True" Click="OrderManagementButton_Click" />
                    <Button x:Name="ApproverButton" Content="承認" Width="120" Margin="0,0,8,8" Visibility="Collapsed" />
                    <Button x:Name="AdminButton" Content="管理" Width="120" Margin="0,0,8,8" Visibility="Collapsed" />
                </WrapPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
