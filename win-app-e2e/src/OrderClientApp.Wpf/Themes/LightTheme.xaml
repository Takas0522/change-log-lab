<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFFFFFFF" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#111827" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#F9FAFB" />

    <Style TargetType="Window">
        <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}" />
    </Style>
</ResourceDictionary>
