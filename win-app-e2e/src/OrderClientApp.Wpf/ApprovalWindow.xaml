<Window x:Class="OrderClientApp.Wpf.ApprovalWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="承認" Height="420" Width="760">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DataGrid x:Name="PendingDataGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="発注番号" Binding="{Binding OrderNumber}" Width="120" />
                <DataGridTextColumn Header="仕入先" Binding="{Binding SupplierName}" Width="220" />
                <DataGridTextColumn Header="発注日" Binding="{Binding OrderedAt}" Width="120" />
                <DataGridTextColumn Header="金額(税込)" Binding="{Binding Amount}" Width="140" />
            </DataGrid.Columns>
        </DataGrid>
        <WrapPanel Grid.Row="1" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="却下" Width="90" Margin="0,0,8,0" Click="RejectButton_Click" />
            <Button Content="承認" Width="90" Click="ApproveButton_Click" />
        </WrapPanel>
    </Grid>
</Window>
