<Window x:Class="OrderClientApp.Wpf.AnalyticsDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="分析ダッシュボード" Height="640" Width="940">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <WrapPanel Margin="0,0,0,12">
            <TextBlock Text="開始日" VerticalAlignment="Center" />
            <DatePicker x:Name="FromDatePicker" Width="130" Margin="8,0,16,0" />
            <TextBlock Text="終了日" VerticalAlignment="Center" />
            <DatePicker x:Name="ToDatePicker" Width="130" Margin="8,0,16,0" />
            <Button Content="集計" Width="90" Click="RefreshButton_Click" />
        </WrapPanel>

        <GroupBox Grid.Row="1" Header="月次集計 / 線グラフデータ" Margin="0,0,0,8">
            <DataGrid x:Name="MonthlyDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="月" Binding="{Binding Month}" Width="100" />
                    <DataGridTextColumn Header="件数" Binding="{Binding OrderCount}" Width="90" />
                    <DataGridTextColumn Header="税抜金額" Binding="{Binding AmountExcludingTax}" Width="130" />
                    <DataGridTextColumn Header="税込金額" Binding="{Binding AmountIncludingTax}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="商品別集計 / 棒グラフデータ">
            <DataGrid x:Name="ProductDataGrid" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="商品コード" Binding="{Binding ProductCode}" Width="120" />
                    <DataGridTextColumn Header="商品名" Binding="{Binding ProductName}" Width="180" />
                    <DataGridTextColumn Header="件数" Binding="{Binding OrderCount}" Width="80" />
                    <DataGridTextColumn Header="数量" Binding="{Binding TotalQuantity}" Width="80" />
                    <DataGridTextColumn Header="税抜金額" Binding="{Binding AmountExcludingTax}" Width="130" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>
    </Grid>
</Window>
