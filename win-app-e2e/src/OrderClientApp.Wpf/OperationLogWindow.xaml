<Window x:Class="OrderClientApp.Wpf.OperationLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="操作ログ" Height="500" Width="900"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,12">
            <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="検索" />
            <TextBox x:Name="KeywordTextBox" Width="220" Margin="0,0,8,0" />
            <TextBlock VerticalAlignment="Center" Margin="0,0,8,0" Text="カテゴリ" />
            <ComboBox x:Name="CategoryComboBox" Width="140" Margin="0,0,8,0">
                <ComboBoxItem Content="" />
                <ComboBoxItem Content="Order" />
                <ComboBoxItem Content="Settings" />
                <ComboBoxItem Content="Product" />
                <ComboBoxItem Content="Supplier" />
            </ComboBox>
            <Button Content="更新" Width="80" Click="RefreshButton_Click" />
        </DockPanel>

        <DataGrid x:Name="LogsDataGrid"
                  Grid.Row="1"
                  IsReadOnly="True"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日時(UTC)" Binding="{Binding CreatedAtUtc}" Width="160" />
                <DataGridTextColumn Header="カテゴリ" Binding="{Binding Category}" Width="100" />
                <DataGridTextColumn Header="操作" Binding="{Binding Action}" Width="100" />
                <DataGridTextColumn Header="実行者" Binding="{Binding Actor}" Width="140" />
                <DataGridTextColumn Header="内容" Binding="{Binding Description}" Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
